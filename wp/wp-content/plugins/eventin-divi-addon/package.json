{
  "name": "eventin-divi-addon",
  "version": "1.0.10",
  "private": true,
  "engines": {
    "node": ">=20.0.0 <24.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "divi-scripts": "1.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sass": "^1.69.0"
  },
  "overrides": {
    "node-sass": "npm:sass@^1.69.0"
  },
  "scripts": {
    "start": "divi-scripts start",
    "build": "divi-scripts build",
    "zip": "divi-scripts build && divi-scripts zip",
    "eject": "divi-scripts eject"
  },
  "browserslist": {
    "development": [
      "last 2 chrome versions",
      "last 2 firefox versions",
      "last 2 edge versions"
    ],
    "production": [
      ">1%",
      "last 4 versions",
      "Firefox ESR",
      "not ie < 11"
    ]
  },
  "cde": {
    "gettext": "eventin-divi-addon",
    "prefix": "eventin"
  }
}
