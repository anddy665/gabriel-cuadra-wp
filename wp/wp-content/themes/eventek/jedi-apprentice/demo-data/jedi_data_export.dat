	position: relative;
	color: transparent;
	animation: text_revealing 0s ease forwards;
	animation-delay: 2s;
	display: inline-block;
	/* opacity: 0; */
}
.container .col-left h1:nth-child(1) {
	animation-delay: 3s;
}
.container .col-left h1:nth-child(2) {
	animation-delay: 4s;
}

.container .col-left h1:nth-child(1) span {
	animation-delay: .5s;
}
.container .col-left h1:nth-child(2) span {
	/* animation-direction: reverse; */
	animation-delay: 1.5s;
}

.container .col-left h1 span {
	content: '';
	position: absolute;
	height: 100%;
	width: 0;
	left: 0;
	top: 0;
	background-color: #F1067C;
	animation: revealing 1s ease forwards;
	animation-delay: .5s;
}

@keyframes text_revealing {
	100% {
		color: white;
	}
}
@keyframes revealing {
	50% {
		width: 100%;
		left: 0;
	}
	100% {
		left: 100%;
		width: 0%;
	}
}

@media only screen and (max-width: 890px) {
	
	.container .col-left h1 {
		display: block;
		width: fit-content;
