a:17:{s:13:"jedi_settings";a:38:{s:19:"jedi_master_version";s:10:"2.8.1 beta";s:13:"include_posts";s:1:"1";s:19:"exclude_posts_by_id";s:0:"";s:26:"include_wp_options_by_slug";s:0:"";s:13:"include_media";s:1:"1";s:15:"include_options";s:1:"1";s:11:"include_css";s:1:"1";s:13:"include_menus";s:1:"1";s:15:"include_widgets";s:1:"1";s:16:"include_homepage";s:1:"1";s:22:"include_custom_maestro";i:0;s:17:"include_posttypes";a:26:{i:0;s:4:"post";i:1;s:4:"page";i:2;s:8:"wp_block";i:3;s:11:"wp_template";i:4;s:16:"wp_template_part";i:5;s:16:"wp_global_styles";i:6;s:13:"wp_navigation";i:7;s:17:"brainaddons-popup";i:8;s:10:"et_tb_item";i:9;s:7:"project";i:10;s:7:"product";i:11;s:17:"product_variation";i:12;s:10:"shop_order";i:13;s:17:"shop_order_refund";i:14;s:11:"shop_coupon";i:15;s:20:"shop_order_placehold";i:16;s:3:"etn";i:17;s:12:"etn-attendee";i:18;s:16:"etn-zoom-meeting";i:19;s:12:"etn-schedule";i:20;s:11:"etn-speaker";i:21;s:16:"et_theme_builder";i:22;s:11:"et_template";i:23;s:16:"et_header_layout";i:24;s:14:"et_body_layout";i:25;s:16:"et_footer_layout";}s:18:"include_categories";s:1:"1";s:16:"include_featured";s:1:"1";s:18:"include_thumbnails";s:1:"0";s:19:"remote_media_import";i:0;s:18:"prevent_thumbnails";i:0;s:12:"beta_updates";s:1:"0";s:11:"homepage_ID";s:2:"42";s:12:"postspage_id";s:1:"0";s:15:"installer_style";s:1:"1";s:20:"installer_menu_title";s:7:"Eventin";s:14:"installer_name";s:7:"Eventin";s:19:"after_import_action";s:16:"remove_demo_data";s:14:"installer_slug";s:7:"eventin";s:17:"installer_message";s:89:"Select your options to import the demo content. It is always recommended to backup first!";s:15:"support_message";s:227:"<p><strong>Documentation</strong><br>Check out the Easy Demo Import knowledgebase for answers to common questions: <a href="https://ferventsolutions.com/knowledgebase_category/jedi/" target="_blank">FerventSolutions.com</a></p>";s:20:"custom_documentation";a:11:{s:5:"intro";a:2:{s:7:"heading";s:12:"Introduction";s:4:"text";s:200:"<p>Imports work best on a fresh installation of WordPress with the appropriate theme installed. It is always recommended that you verify that you have a good backup prior to importing new content.</p>";}s:13:"include_posts";a:2:{s:7:"heading";s:21:"Include Posts & Pages";s:4:"text";s:165:"<p>This option enables the importing of posts and pages as well as custom post types. Current posts, pages and custom post types will not be modified or removed.</p>";}s:13:"include_media";a:2:{s:7:"heading";s:21:"Include Media Library";s:4:"text";s:125:"<p>Check this to import the demo images into your WordPress Media Library. Current items will not be modified or removed.</p>";}s:15:"include_options";a:2:{s:7:"heading";s:53:"Include Divi Theme Options & Divi Customizer Settings";s:4:"text";s:106:"<p>Notice: This option will overwrite all the current Divi Theme Options and Divi Customizer Settings.</p>";}s:26:"include_divi_theme_builder";a:2:{s:7:"heading";s:31:"Include Divi Theme Builder Data";s:4:"text";s:75:"<p>Notice: This option may overwrite some Divi Theme Builder Templates.</p>";}s:11:"include_css";a:2:{s:7:"heading";s:33:"Include Customizer Additional CSS";s:4:"text";s:155:"<p>This option will add any extra CSS from the demo content to the Customizer's Additional CSS. This is typically used when a child theme is not setup.</p>";}s:13:"include_menus";a:2:{s:7:"heading";s:22:"Include Menu Structure";s:4:"text";s:135:"<p>Check this to recreate the menu structure from the demo content. Your current menus may be modified depending on their settings.</p>";}s:15:"include_widgets";a:2:{s:7:"heading";s:23:"Include Widget Settings";s:4:"text";s:63:"<p>Notice: This will overwrite all current widget settings.</p>";}s:16:"include_homepage";a:2:{s:7:"heading";s:41:"Automatically Set Homepage And Posts Page";s:4:"text";s:99:"<p>This option will update the WordPress setting to display a static front page and posts page.</p>";}s:18:"include_wp_options";a:2:{s:7:"heading";s:18:"Include WP Options";s:4:"text";s:120:"<p>Notice: This will overwrite some database settings. Make sure you have a good backup to revert back to if needed.</p>";}s:20:"after_import_message";a:2:{s:7:"heading";s:20:"After Import Message";s:4:"text";s:259:"<h2>Thank you for installing and importing!</h2><p><strong><a href="/" target="_blank">Check out your new home page!</a></strong></p><p>Importing again will create duplicate content. Would you like to save a little space and remove the demo content files?</p>";}}s:17:"import_batch_size";i:10;s:23:"import_media_batch_size";i:10;s:19:"import_accent_color";s:7:"#47137b";s:9:"elementor";a:1:{s:15:"include_options";i:0;}s:26:"include_divi_theme_builder";s:1:"1";s:18:"selected_posttypes";a:27:{s:4:"post";s:1:"1";s:4:"page";s:1:"1";s:8:"wp_block";s:1:"1";s:11:"wp_template";s:1:"1";s:16:"et_theme_builder";i:1;s:11:"et_template";i:1;s:16:"et_header_layout";i:1;s:14:"et_body_layout";i:1;s:16:"et_footer_layout";i:1;s:7:"project";s:1:"1";s:7:"product";s:1:"1";s:17:"product_variation";s:1:"1";s:10:"shop_order";s:1:"1";s:17:"shop_order_refund";s:1:"1";s:11:"shop_coupon";s:1:"1";s:3:"etn";s:1:"1";s:12:"etn-attendee";s:1:"1";s:16:"etn-zoom-meeting";s:1:"1";s:12:"etn-schedule";s:1:"1";s:11:"etn-speaker";s:1:"1";s:12:"et_pb_layout";i:0;s:17:"brainaddons-popup";s:1:"1";s:16:"wp_template_part";s:1:"1";s:16:"wp_global_styles";s:1:"1";s:13:"wp_navigation";s:1:"1";s:20:"shop_order_placehold";s:1:"1";s:10:"et_tb_item";s:1:"1";}s:16:"selected_plugins";a:8:{s:18:"_jedi_master_nonce";s:18:"_jedi_master_nonce";s:16:"_wp_http_referer";s:16:"_wp_http_referer";s:15:"addons-for-divi";s:15:"addons-for-divi";s:18:"eventin-divi-addon";s:18:"eventin-divi-addon";s:15:"popups-for-divi";s:15:"popups-for-divi";s:24:"supreme-modules-for-divi";s:24:"supreme-modules-for-divi";s:11:"woocommerce";s:11:"woocommerce";s:17:"wp-event-solution";s:17:"wp-event-solution";}s:24:"selected_nonrepo_plugins";a:0:{}s:12:"export_stats";a:1:{s:7:"plugins";a:2:{s:4:"repo";i:8;s:7:"nonrepo";i:100;}}